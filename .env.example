# Copy to .env and fill in values (do not commit .env)

# MySQL — required for API + Drizzle (MySQL 8.0+ recommended)
# Example: mysql://USER:PASSWORD@127.0.0.1:3306/chatsystem
DATABASE_URL=

# Session signing — required in production (use a long random string)
SESSION_SECRET=

# Optional: public site URL for Open Graph image URLs at build time
# SITE_URL=https://your-domain.com

# Development only: auto-login first user in DB (or DEV_USER_ID) so chat API returns 200 instead of 401
# DEV_AUTO_LOGIN=true
# DEV_USER_ID=
